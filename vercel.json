{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "devCommand": "cd client && vite --port $PORT",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|src/|@|node_modules/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/glucose/egvs.ts": {
      "maxDuration": 30
    }
  }
}
