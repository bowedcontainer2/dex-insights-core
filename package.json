{
  "name": "cgminsights-mvp",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm run dev -w client",
    "dev:local": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "cd client && npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@supabase/supabase-js": "^2.49.0",
    "@vercel/functions": "^1.5.0",
    "openai": "^6.32.0"
  },
  "devDependencies": {
    "@vercel/node": "^5.1.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3",
    "vercel": "^50.33.1",
    "vitest": "^4.1.0"
  }
}
